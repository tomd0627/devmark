{
  "name": "devmark",
  "version": "0.1.0",
  "description": "AI-powered bookmark manager — automatically tags and summarises saved URLs using Claude",
  "private": true,
  "type": "module",
  "scripts": {
    "lint:js": "eslint src/js netlify/functions",
    "lint:css": "stylelint src/css/**/*.css",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{html,css,js,json}": [
      "prettier --write"
    ],
    "*.js": [
      "eslint --fix"
    ],
    "*.css": [
      "stylelint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "stylelint": "^17.10.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1"
  }
}
